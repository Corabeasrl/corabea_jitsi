# corabea_jitsi — env vars required by the transcription pipeline.
# These go into /opt/jitsi/.env (the docker-jitsi-meet env). NEVER commit real
# secrets — this file documents the keys with placeholders only.

# --- Transcription on/off (web UI + jicofo) ---
ENABLE_TRANSCRIPTIONS=true

# --- Jigasi transcriber: engine + ignition STT + audio recording ---
# Engine class stays VoskTranscriptionService, but it points at our null-STT
# (no real recognition — the draft transcript is discarded; Whisper runs elsewhere).
JIGASI_TRANSCRIBER_CUSTOM_SERVICE=org.jitsi.jigasi.transcription.VoskTranscriptionService
JIGASI_TRANSCRIBER_VOSK_URL=ws://null-stt:2700
JIGASI_TRANSCRIBER_RECORD_AUDIO=true
# XMPP password for the transcriber account (generate a strong one)
JIGASI_TRANSCRIBER_PASSWORD=__CHANGEME__

# --- S3 / MinIO (shared with the Jibri finalize upload) ---
# URL carries endpoint + credentials: https://ACCESS_KEY:SECRET_KEY@s3.host
S3_HOST=https://__ACCESS_KEY__:__SECRET_KEY__@s3.corabea.it
S3_BUCKET=corabea
S3_PREFIX=recordings

# --- Custom prosody module (mod_corabea_call_events) ---
# Must be loaded: XMPP_MUC_MODULES=token_moderation,corabea_call_events
# Backend webhook the module POSTs call lifecycle events to (separate host):
CORABEA_CALL_EVENTS_URL=https://api.example.com/webhooks/prosody
CORABEA_CALL_EVENTS_SECRET=__CHANGEME__

# Reminder: the OPERATOR's appointment JWT must set moderator=true, otherwise
# Jicofo refuses the auto-start transcription request (only moderators may start).
